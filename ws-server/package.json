{
  "name": "type-sprint-ws-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "bun test"
  },
  "dependencies": {
    "@socket.io/bun-engine": "0.1.1",
    "socket.io": "4.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "1.3.11",
    "socket.io-client": "4.8.3",
    "typescript": "5.9.3"
  }
}
